{
  "name": "founderfloor",
  "version": "0.1.0",
  "private": true,
  "description": "A walkable 2D expo floor for startups — booths, founders, chat, connections.",
  "scripts": {
    "dev": "concurrently -n web,ws -c blue,yellow \"next dev\" \"node server/index.mjs\"",
    "dev:web": "next dev",
    "dev:ws": "node server/index.mjs",
    "build": "next build",
    "start": "concurrently -n web,ws -c blue,yellow \"next start\" \"node server/index.mjs\"",
    "typecheck": "tsc --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "concurrently": "9.1.0",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/ws": "8.5.12",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "typescript": "5.5.3"
  }
}
